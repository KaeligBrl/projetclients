{% extends 'base.html.twig' %}

{% block title %}Facturation sites web - {% block title_base %}{{ parent() }}{% endblock %}{% endblock %}

{% block content %}

	<h1 class="text-center color-white">Facturation sites web</h1>
	<div class="mb-3"></div>
	<div class="separator"></div>
	{% if hasUnavailableSteps %}
		<div class="alert alert-warning mt-3 mb-3" role="alert">
			Certaines cases sont grisées car aucun email destinataire n'est configuré dans Paramètres > Emails facturation.
		</div>
	{% endif %}
	<div class="alert mt-3 mb-3" role="alert" style="background:#023D5C; border-left: 3px solid #FFD600; color:#fff;">
		<i class="fas fa-info-circle me-1" style="color:#FFD600;"></i>
		Les colonnes <strong>Facturé</strong> et <strong>Payé</strong> sont remplies par le service administratif. Vous recevrez un email automatique à chaque étape.
	</div>
	<div class="row">
		<div class="col padding-mobile">
			{% if is_granted('IS_AUTHENTICATED_FULLY') and is_granted('ROLE_ADMIN') %}
				{% if billings is empty %}
					<p class="text-center color-white mt-2">Aucun projet trouvé.</p>
				{% else %}
					<div class="table-responsive">
				<table class="table mb-5 table-bordered" style="min-width: 900px;">
						<thead class="bg-blue-dark-light table-borderless">
							<tr>
								<th class="color-yellow text-bold" rowspan="2" scope="col">Client</th>
								<th class="color-yellow text-bold text-center" colspan="3">Acompte</th>
								<th class="color-yellow text-bold text-center" colspan="3">Maquette envoyée</th>
								<th class="color-yellow text-bold text-center" colspan="3">Formation</th>
								<th class="color-yellow text-bold text-center" colspan="3">Envoyé au service admin</th>
							</tr>
							<tr style="background:#012d45;">
								<th class="color-white text-center" style="font-size:.75rem;">Vous</th>
								<th class="color-yellow text-center" style="font-size:.75rem;">Facturé</th>
								<th class="color-yellow text-center" style="font-size:.75rem;">Payé</th>
								<th class="color-white text-center" style="font-size:.75rem;">Vous</th>
								<th class="color-yellow text-center" style="font-size:.75rem;">Facturé</th>
								<th class="color-yellow text-center" style="font-size:.75rem;">Payé</th>
								<th class="color-white text-center" style="font-size:.75rem;">Vous</th>
								<th class="color-yellow text-center" style="font-size:.75rem;">Facturé</th>
								<th class="color-yellow text-center" style="font-size:.75rem;">Payé</th>
								<th class="color-white text-center" style="font-size:.75rem;">Vous</th>
								<th class="color-yellow text-center" style="font-size:.75rem;">Facturé</th>
								<th class="color-yellow text-center" style="font-size:.75rem;">Payé</th>
							</tr>
						</thead>
						<tbody class="bg-blue-dark">
							{% for billing in billings %}
								<tr>
									<td class="color-white text-bold align-middle" style="white-space:nowrap;">{{ billing.websiteProject.customer }}</td>
									{# Acompte #}
									<td class="text-center align-middle">
										<input type="checkbox"
											class="billing-deposit form-check-input"
											{{ billing.deposit ? 'checked' : '' }}
											data-mail-enabled="{{ mailEnabled.deposit ? '1' : '0' }}"
											data-billing-deposit="{{ billing.id }}">
									</td>
									<td class="text-center align-middle">
										<input type="checkbox" class="form-check-input" {{ billing.depositInvoiced ? 'checked' : '' }} disabled title="Coché par le service admin">
									</td>
									<td class="text-center align-middle">
										<input type="checkbox" class="form-check-input" {{ billing.depositPaid ? 'checked' : '' }} disabled title="Coché par le service admin">
									</td>
									{# Maquette #}
									<td class="text-center align-middle">
										<input type="checkbox"
											class="billing-mockup-sent form-check-input"
											{{ billing.mockupSent ? 'checked' : '' }}
											data-mail-enabled="{{ mailEnabled.mockup_sent ? '1' : '0' }}"
											data-billing-mockup-sent="{{ billing.id }}">
									</td>
									<td class="text-center align-middle">
										<input type="checkbox" class="form-check-input" {{ billing.mockupSentInvoiced ? 'checked' : '' }} disabled title="Coché par le service admin">
									</td>
									<td class="text-center align-middle">
										<input type="checkbox" class="form-check-input" {{ billing.mockupSentPaid ? 'checked' : '' }} disabled title="Coché par le service admin">
									</td>
									{# Formation #}
									<td class="text-center align-middle">
										<input type="checkbox"
											class="billing-onboarding-training form-check-input"
											{{ billing.onboardingTraining ? 'checked' : '' }}
											data-mail-enabled="{{ mailEnabled.onboarding_training ? '1' : '0' }}"
											data-billing-onboarding-training="{{ billing.id }}">
									</td>
									<td class="text-center align-middle">
										<input type="checkbox" class="form-check-input" {{ billing.onboardingTrainingInvoiced ? 'checked' : '' }} disabled title="Coché par le service admin">
									</td>
									<td class="text-center align-middle">
										<input type="checkbox" class="form-check-input" {{ billing.onboardingTrainingPaid ? 'checked' : '' }} disabled title="Coché par le service admin">
									</td>
									{# Envoi admin #}
									<td class="text-center align-middle">
										<input type="checkbox"
											class="billing-status form-check-input"
											{{ billing.status ? 'checked' : '' }}
											data-mail-enabled="{{ mailEnabled.status ? '1' : '0' }}"
											data-billing-status="{{ billing.id }}">
									</td>
									<td class="text-center align-middle">
										<input type="checkbox" class="form-check-input" {{ billing.statusInvoiced ? 'checked' : '' }} disabled title="Coché par le service admin">
									</td>
									<td class="text-center align-middle">
										<input type="checkbox" class="form-check-input" {{ billing.statusPaid ? 'checked' : '' }} disabled title="Coché par le service admin">
									</td>
								</tr>
							{% endfor %}
						</tbody>
					</table>
				</div>
				{% endif %}
			{% endif %}
		</div>
	</div>

{% endblock %}

