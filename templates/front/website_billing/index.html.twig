{% extends 'base.html.twig' %}

{% block title %}Facturation sites web - {% block title_base %}{{ parent() }}{% endblock %}{% endblock %}

{% block content %}

	<h1 class="text-center color-white">Facturation sites web</h1>
	<div class="mb-3"></div>
	<div class="separator"></div>
	{% if hasUnavailableSteps %}
		<div class="alert alert-warning mt-3 mb-3" role="alert">
			Certaines cases sont grisées car aucun email destinataire n'est configuré dans Paramètres > Emails facturation.
		</div>
	{% endif %}
	<div class="alert mt-3 mb-3 billing-info-alert" role="alert">
		<i class="fas fa-info-circle me-1 billing-info-icon"></i>
		{% if is_granted('ROLE_ADMIN') %}
			Les colonnes <strong>Facturé</strong> et <strong>Payé</strong> sont à votre charge. Vous pouvez cocher les cases au fur et à mesure de l'avancement de la facturation.
		{% else %}
			<strong>Workflow :</strong> Shebam coche <strong>Demander la facturation</strong> → vous pouvez ensuite cocher <strong>Facturé</strong> puis <strong>Payé</strong>.
			<br><small class="billing-info-note">Les cases grisées ne sont pas encore disponibles — attendez la demande de Shebam.
</small>
		{% endif %}
	</div>
	<div class="row">
		<div class="col padding-mobile">
			{% if is_granted('IS_AUTHENTICATED_FULLY') and is_granted('ROLE_COMPTA') %}
				{% if billings is empty %}
					<p class="text-center color-white mt-2">Aucun projet trouvé.</p>
				{% else %}
					<div class="table-responsive">
						<table class="table mb-5 table-bordered billing-table billing-table--website">
							<thead class="bg-blue-dark-light table-borderless">
								<tr>
									<th class="color-yellow text-bold" rowspan="2" scope="col">Client</th>
									<th class="color-yellow text-bold text-center" colspan="3">Acompte / Devis signé</th>
									<th class="color-yellow text-bold text-center" colspan="3">Maquettes envoyées</th>
									<th class="color-yellow text-bold text-center" colspan="3">Formation de prise / Mise en ligne / Solde restant</th>
								</tr>
								<tr class="billing-subhead-row">
									<th class="color-white text-center billing-subhead" title="Cocher déclenche un email au client">Demander la facturation</th>
									<th class="color-yellow text-center billing-subhead">Facturé</th>
									<th class="color-yellow text-center billing-subhead">Payé</th>
									<th class="color-white text-center billing-subhead" title="Cocher déclenche un email au client">Demander la facturation</th>
									<th class="color-yellow text-center billing-subhead">Facturé</th>
									<th class="color-yellow text-center billing-subhead">Payé</th>
									<th class="color-white text-center billing-subhead" title="Cocher déclenche un email au client">Demander la facturation</th>
									<th class="color-yellow text-center billing-subhead">Facturé</th>
									<th class="color-yellow text-center billing-subhead">Payé</th>
								</tr>
							</thead>
							<tbody class="bg-blue-dark">
								{% for billing in billings %}
									<tr>
										<td class="color-white text-bold align-middle billing-client-cell">{{ billing.websiteProject.customer }}</td>
										{# Acompte #}
										<td class="text-center align-middle">
											<input type="checkbox"
												class="billing-deposit form-check-input"
												{{ billing.deposit ? 'checked' : '' }}
												{{ not is_granted('ROLE_ADMIN') ? 'disabled' : '' }}
												data-mail-enabled="{{ mailEnabled.deposit ? '1' : '0' }}"
												data-billing-deposit="{{ billing.id }}">
										</td>
										<td class="text-center align-middle">
											<input type="checkbox" class="billing-deposit-invoiced form-check-input" {{ billing.depositInvoiced ? 'checked' : '' }} data-billing-deposit-invoiced="{{ billing.id }}">
										</td>
										<td class="text-center align-middle">
											<input type="checkbox"
												class="billing-deposit-paid form-check-input"
												{{ billing.depositPaid ? 'checked' : '' }}
												{{ (not is_granted('ROLE_ADMIN') or not billing.depositInvoiced) ? 'disabled' : '' }}
												data-role-required="admin"
												data-billing-deposit-paid="{{ billing.id }}">
										</td>
										{# Maquettes #}
										<td class="text-center align-middle">
											<input type="checkbox"
												class="billing-mockup-sent form-check-input"
												{{ billing.mockupSent ? 'checked' : '' }}
												{{ not is_granted('ROLE_ADMIN') ? 'disabled' : '' }}
												data-mail-enabled="{{ mailEnabled.mockup_sent ? '1' : '0' }}"
												data-billing-mockup-sent="{{ billing.id }}">
										</td>
										<td class="text-center align-middle">
											<input type="checkbox" class="billing-mockup-invoiced form-check-input" {{ billing.mockupSentInvoiced ? 'checked' : '' }} data-billing-mockup-invoiced="{{ billing.id }}">
										</td>
										<td class="text-center align-middle">
											<input type="checkbox"
												class="billing-mockup-paid form-check-input"
												{{ billing.mockupSentPaid ? 'checked' : '' }}
												{{ (not is_granted('ROLE_ADMIN') or not billing.mockupSentInvoiced) ? 'disabled' : '' }}
												data-role-required="admin"
												data-billing-mockup-paid="{{ billing.id }}">
										</td>
										{# Formation #}
										<td class="text-center align-middle">
											<input type="checkbox"
												class="billing-onboarding-training form-check-input"
												{{ billing.onboardingTraining ? 'checked' : '' }}
												{{ not is_granted('ROLE_ADMIN') ? 'disabled' : '' }}
												data-mail-enabled="{{ mailEnabled.onboarding_training ? '1' : '0' }}"
												data-billing-onboarding-training="{{ billing.id }}">
										</td>
										<td class="text-center align-middle">
											<input type="checkbox" class="billing-training-invoiced form-check-input" {{ billing.onboardingTrainingInvoiced ? 'checked' : '' }} data-billing-training-invoiced="{{ billing.id }}">
										</td>
										<td class="text-center align-middle">
											<input type="checkbox"
												class="billing-training-paid form-check-input"
												{{ billing.onboardingTrainingPaid ? 'checked' : '' }}
												{{ (not is_granted('ROLE_ADMIN') or not billing.onboardingTrainingInvoiced) ? 'disabled' : '' }}
												data-role-required="admin"
												data-billing-training-paid="{{ billing.id }}">
										</td>
									</tr>
								{% endfor %}
							</tbody>
						</table>
					</div>
				{% endif %}
			{% endif %}
		</div>
	</div>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('assets/js/website_billing_checkbox.js') }}"></script>
{% endblock %}


