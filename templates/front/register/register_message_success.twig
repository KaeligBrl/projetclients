{% extends 'base_login_register.html.twig' %}

{% block title %}Inscription Réussie - {% block title_base %}{{ parent() }}{% endblock %}{% endblock %}

{% block content %}
<meta http-equiv="refresh" content="6;url={{ path('home') }}"/>

<a href="{{ path('home') }}">
    <img class="d-block mx-auto mb-4 auth-logo" src="{{ asset('/assets/images/logo-projet-clients.png') }}" alt="Logo Projets Clients">
</a>

<div class="container-custom text-center">
    <div class="form-general auth-success-card">
        <div class="auth-success-badge">✓</div>

        <h1 class="mb-2 auth-page-title">Inscription réussie</h1>
        <div class="separator mb-4"></div>

        <p class="mb-2 auth-text-white">Ton compte a bien été créé.</p>
        <p class="mb-4 auth-text-soft">Redirection automatique vers la connexion dans 6 secondes.</p>

        <a href="{{ path('home') }}" class="btn btn-submit w-100 auth-submit-btn">Aller à la connexion maintenant</a>
    </div>
</div>
{% endblock %}