{% extends 'base_login_register.html.twig' %}

{% block title %}Inscription - {% block title_base %}{{ parent() }}{% endblock %}{% endblock %}

{% block content %}
    <a href="{{ path('home') }}">
        <img class="d-block mx-auto mb-4 auth-logo" src="{{ asset('/assets/images/logo-projet-clients.png') }}" alt="Logo Projets Clients">
    </a>

    <div class="container-custom">
        <h1 class="text-center mb-1 auth-page-title">Inscription</h1>
        <div class="separator mb-4"></div>

        {% if notification %}
            <div class="alert text-center auth-notification-box">
                {{ notification }}
            </div>
        {% endif %}

        <div class="form-general">
            {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

            <div class="form-group mb-3">
                {{ form_label(form.firstname, 'Prénom', {'label_attr': {'class': 'text-white mb-1 auth-form-label'}}) }}
                {{ form_widget(form.firstname, {'attr': {'class': 'form-control', 'placeholder': 'Votre prénom'}}) }}
                {{ form_errors(form.firstname) }}
            </div>

            <div class="form-group mb-3">
                {{ form_label(form.lastname, 'Nom', {'label_attr': {'class': 'text-white mb-1 auth-form-label'}}) }}
                {{ form_widget(form.lastname, {'attr': {'class': 'form-control', 'placeholder': 'Votre nom'}}) }}
                {{ form_errors(form.lastname) }}
            </div>

            <div class="form-group mb-3">
                {{ form_label(form.email, 'Email', {'label_attr': {'class': 'text-white mb-1 auth-form-label'}}) }}
                {{ form_widget(form.email, {'attr': {'class': 'form-control', 'placeholder': 'votre@email.com'}}) }}
                {{ form_errors(form.email) }}
            </div>

            <div class="form-group mb-3">
                <label class="text-white mb-1 auth-form-label">Mot de passe</label>
                {{ form_widget(form.password.first, {'attr': {'class': 'form-control', 'placeholder': '••••••••'}}) }}
                {{ form_errors(form.password.first) }}
            </div>

            <div class="form-group mb-4">
                <label class="text-white mb-1 auth-form-label">Confirmation du mot de passe</label>
                {{ form_widget(form.password.second, {'attr': {'class': 'form-control', 'placeholder': '••••••••'}}) }}
                {{ form_errors(form.password.second) }}
            </div>

            <div class="text-center">
                <button type="submit" class="btn btn-submit w-100 auth-submit-btn">
                    Créer mon compte
                </button>
            </div>

            {{ form_end(form) }}
        </div>

        <p class="text-center mt-4 mb-0">
            <span class="auth-muted-text">Déjà inscrit ?</span>
            <a href="{{ path('home') }}" class="text-login-link ms-1 auth-link-text">Connectez-vous</a>
        </p>
    </div>
{% endblock %}