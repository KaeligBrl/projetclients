{% extends 'base.html.twig' %}

{% block title %}Modifier - {{project.customer }} - {% block title_base %}{{ parent() }}{% endblock %}{% endblock %}

{% block body %}
	{% block content %}
		<div class="container-fluid layout-main-offset">
			<div class="container-custom">
				<h1 class="text-center mb-3" style="color: var(--color-yellow); font-family: 'Gotham'; font-size: 1.8rem;">Modification du suivi <i class="fas fa-arrow-right"></i> {{project.customer }}</h1>
				<div class="separator mb-4"></div>

				{% if notification %}
					<div class="alert text-center" style="background: rgba(106, 191, 165, 0.2); color: var(--green-light); border-radius: 10px; border: 1px solid var(--green-light); margin-bottom: 20px;">
						{{ notification }}
						<div style="margin-top: 15px;">
							<a href="{{ path('finished_projects') }}" class="btn btn-submit" style="display: inline-block; text-decoration: none;">Retourner à la liste</a>
						</div>
					</div>
				{% else %}
					<div class="form-general">
						{{ form_start(form_project_modify, {'attr': {'novalidate': 'novalidate'}}) }}

						<div class="row">
							<div class="col-lg-6">
								<div class="form-group mb-3">
									{{ form_label(form_project_modify.wordpressInstallation, 'Date d\'installation du WordPress', {'label_attr': {'class': 'text-white mb-1', 'style': 'font-family: Gotham;'}}) }}
									{{ form_widget(form_project_modify.wordpressInstallation, {'attr': {'class': 'form-control'}}) }}
									{{ form_errors(form_project_modify.wordpressInstallation) }}
								</div>

								<div class="form-group mb-4">
									{{ form_label(form_project_modify.domainText, 'Nom de domaine', {'label_attr': {'class': 'text-white mb-1', 'style': 'font-family: Gotham;'}}) }}
									{{ form_widget(form_project_modify.domainText, {'attr': {'class': 'form-control'}}) }}
									{{ form_errors(form_project_modify.domainText) }}
								</div>
							</div>

							<div class="col-lg-6">
								<div class="form-group mb-4">
									{{ form_label(form_project_modify.online, 'Mise en ligne', {'label_attr': {'class': 'text-white mb-1', 'style': 'font-family: Gotham;'}}) }}
									{{ form_widget(form_project_modify.online, {'attr': {'class': 'form-control'}}) }}
									{{ form_errors(form_project_modify.online) }}
								</div>
							</div>
						</div>

						<div class="text-center mt-4">
							{{ form_widget(form_project_modify.submit, {'attr': {'class': 'btn btn-submit w-100', 'style': 'font-family: Gotham; font-size: 1rem; padding: 12px;'}}) }}
						</div>

						{{ form_end(form_project_modify) }}
					</div>
				{% endif %}
			</div>
		</div>
	{% endblock %}
{% endblock %}