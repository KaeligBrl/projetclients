{% extends 'base.html.twig' %}

{% block title %}Modifier - {{project.customer }} - {% block title_base %}{{ parent() }}{% endblock %}{% endblock %}

{% block body %}
	{% block content %}
		<div class="container-fluid layout-main-offset">
			<div class="container-custom">
				<h1 class="text-center mb-3 page-title-accent">Modification du suivi <i class="fas fa-arrow-right"></i> {{project.customer }}</h1>
				<div class="separator mb-4"></div>

				{% if notification %}
					<div class="alert text-center success-notice-box">
						{{ notification }}
						<div class="success-notice-actions">
							<a href="{{ path('website_projects_finished') }}" class="btn btn-submit btn-inline-link">Retourner à la liste</a>
						</div>
					</div>
				{% else %}
					<div class="form-general">
						{{ form_start(form_project_modify, {'attr': {'novalidate': 'novalidate'}}) }}

						<div class="row">
							<div class="col-lg-12">
								<div class="form-group mb-3">
									{{ form_row(form_project_modify.wordpressInstallation) }}
									{{ form_row(form_project_modify.online) }}
									{{ form_row(form_project_modify.domainText) }}
									{{ form_row(form_project_modify.submit) }}
								</div>
							</div>
						</div>

						{{ form_end(form_project_modify) }}
					</div>
				{% endif %}
			</div>
		</div>
	{% endblock %}
{% endblock %}