{% extends 'base.html.twig' %}

{% block title %}Ajouter un projet - {% block title_base %}{{ parent() }}{% endblock %}{% endblock %}

{% block body %}
	{% block content %}
		<div class="container-fluid layout-main-offset">
			<div class="container-custom">
				<h1 class="text-center mb-3 page-title-accent">Ajouter un projet</h1>
				<div class="separator mb-4"></div>

				{% if notification %}
					<div class="alert text-center success-notice-box">
						{{ notification }}
						<div class="success-notice-actions">
							<a href="{{ path('website_project') }}" class="btn btn-submit btn-inline-link">Retourner à la liste</a>
						</div>
					</div>
				{% else %}
					<div class="form-general">
						{{ form_start(form_project_add, {'attr': {'novalidate': 'novalidate'}}) }}

						<div class="row">
							<div class="col-lg-6">
								<div class="form-group mb-3">
									{{ form_label(form_project_add.customer, 'Client', {'label_attr': {'class': 'text-white mb-1 form-label-gotham'}}) }}
									{{ form_widget(form_project_add.customer, {'attr': {'class': 'form-control'}}) }}
									{{ form_errors(form_project_add.customer) }}
								</div>

								<div class="form-group mb-3">
									{{ form_label(form_project_add.wordpressInstallation, 'Installation WordPress', {'label_attr': {'class': 'text-white mb-1 form-label-gotham'}}) }}
									{{ form_widget(form_project_add.wordpressInstallation, {'attr': {'class': 'form-control'}}) }}
									{{ form_errors(form_project_add.wordpressInstallation) }}
								</div>

								<div class="form-group mb-3">
									{{ form_label(form_project_add.online, 'Mise en ligne', {'label_attr': {'class': 'text-white mb-1 form-label-gotham'}}) }}
									{{ form_widget(form_project_add.online, {'attr': {'class': 'form-control'}}) }}
									{{ form_errors(form_project_add.online) }}
								</div>
							</div>

							<div class="col-lg-6">
								<div class="form-group mb-3">
									{{ form_widget(form_project_add.customerbrief, {'attr': {'class': 'form-check-input'}}) }}
									{{ form_label(form_project_add.customerbrief, 'Brief client reçu', {'label_attr': {'class': 'text-white form-check-label form-label-gotham'}}) }}
								</div>

								<div class="form-group mb-3">
									{{ form_widget(form_project_add.customercontentreception, {'attr': {'class': 'form-check-input'}}) }}
									{{ form_label(form_project_add.customercontentreception, 'Contenu client reçu', {'label_attr': {'class': 'text-white form-check-label form-label-gotham'}}) }}
								</div>

								<div class="form-group mb-3">
									{{ form_widget(form_project_add.webdesignprogress, {'attr': {'class': 'form-check-input'}}) }}
									{{ form_label(form_project_add.webdesignprogress, 'Maquette en cours', {'label_attr': {'class': 'text-white form-check-label form-label-gotham'}}) }}
								</div>

								<div class="form-group mb-3">
									{{ form_widget(form_project_add.webdesignsend, {'attr': {'class': 'form-check-input'}}) }}
									{{ form_label(form_project_add.webdesignsend, 'Maquette envoyée', {'label_attr': {'class': 'text-white form-check-label form-label-gotham'}}) }}
								</div>

								<div class="form-group mb-3">
									{{ form_widget(form_project_add.webdesignvalidated, {'attr': {'class': 'form-check-input'}}) }}
									{{ form_label(form_project_add.webdesignvalidated, 'Maquette validée', {'label_attr': {'class': 'text-white form-check-label form-label-gotham'}}) }}
								</div>

								<div class="form-group mb-3">
									{{ form_widget(form_project_add.webintegration, {'attr': {'class': 'form-check-input'}}) }}
									{{ form_label(form_project_add.webintegration, 'Intégration web faite', {'label_attr': {'class': 'text-white form-check-label form-label-gotham'}}) }}
								</div>

								<div class="form-group mb-4">
									{{ form_widget(form_project_add.webtraining, {'attr': {'class': 'form-check-input'}}) }}
									{{ form_label(form_project_add.webtraining, 'Formation de prise en main', {'label_attr': {'class': 'text-white form-check-label form-label-gotham'}}) }}
								</div>

								<div class="form-group mb-3">
									{{ form_widget(form_project_add.comingsoon, {'attr': {'class': 'form-check-input'}}) }}
									{{ form_label(form_project_add.comingsoon, 'Page de maintenance créée', {'label_attr': {'class': 'text-white form-check-label form-label-gotham'}}) }}
								</div>
							</div>
						</div>

						<div class="text-center mt-4">
							{{ form_widget(form_project_add.submit, {'attr': {'class': 'btn btn-submit w-100 auth-submit-btn'}}) }}
						</div>

						{{ form_end(form_project_add) }}
					</div>
				{% endif %}
			</div>
		</div>
	{% endblock %}
{% endblock %}