{% extends 'base.html.twig' %}

{% block title %}Liste des projets - {% block title_base %}{{ parent() }}{% endblock %}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tom-select@2.3.1/dist/css/tom-select.default.min.css">
    <link rel="stylesheet" href="{{ asset('assets/css/front/tom-select-theme.css') }}">
{% endblock %}

{% block content %}
<div class="container py-4">

    <h1 class="text-center color-white mb-1">Liste des projets</h1>
    <p class="color-white text-center mb-3" style="opacity:.7; font-size:.9rem;">
        {{ project_count }} site{{ project_count > 1 ? 's' : '' }} référencé{{ project_count > 1 ? 's' : '' }}
    </p>
    <div class="separator mb-4"></div>

    {% if is_granted('ROLE_ADMIN') %}
    <div class="d-flex justify-content-end mb-3">
        <a href="{{ path('listing_projects_add') }}" class="btn btn-sm fw-bold"
           style="background:#FFD600;color:#00263A;">
            <i class="fas fa-plus-circle me-1"></i> Ajouter un site
        </a>
    </div>
    {% endif %}

    {# ── Filtres Tom Select ── #}
    <div class="listing-filters mb-4">
        <div class="row g-3">
            <div class="col-md-4">
                <label class="filter-label">Activité</label>
                <select id="ts-activity" multiple placeholder="Filtrer par activité…">
                    {% for f in filters %}
                    <option value="{{ f.id }}">{{ f.nameActivities }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-4">
                <label class="filter-label">Type de site</label>
                <select id="ts-website" multiple placeholder="Filtrer par type de site…">
                    {% for f in filterWebsites %}
                    <option value="{{ f.id }}">{{ f.nameWebsites }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-4">
                <label class="filter-label">Type d'entreprise</label>
                <select id="ts-enterprise" multiple placeholder="Filtrer par entreprise…">
                    {% for f in filterEnterprises %}
                    <option value="{{ f.id }}">{{ f.nameEnterpriseType }}</option>
                    {% endfor %}
                </select>
            </div>
        </div>
        <div class="mt-2">
            <button type="button" id="reset-filters" class="btn btn-sm btn-outline-light" style="display:none;">
                <i class="fas fa-times me-1"></i> Réinitialiser
            </button>
        </div>
    </div>

    {# ── Tableau ── #}
    <div class="table-responsive">
        <table class="table table-bordered mb-5" id="listing-table">
            <thead class="bg-blue-dark-light">
                <tr>
                    <th class="color-yellow">Entreprise</th>
                    <th class="color-yellow">Site internet</th>
                    <th class="color-yellow">Activité</th>
                    <th class="color-yellow">Type de site</th>
                    <th class="color-yellow">Type d'entreprise</th>
                    {% if is_granted('ROLE_ADMIN') %}<th class="color-yellow">Action</th>{% endif %}
                </tr>
            </thead>
            <tbody id="listing-tbody" class="bg-blue-dark">
                <tr><td colspan="6" class="text-center color-white py-4">
                    <i class="fas fa-spinner fa-spin me-2"></i> Chargement…
                </td></tr>
            </tbody>
        </table>
        <p id="no-results" class="text-center color-white mt-3" style="display:none;">
            Aucun résultat pour ces filtres.
        </p>
    </div>

</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/tom-select@2.3.1/dist/js/tom-select.complete.min.js"></script>
    <script>
        window.LISTING_SEARCH_URL   = "{{ path('listing_projects_search') }}";
        window.LISTING_MODIFY_PATH  = "{{ path('listing_projects_modify', {id: '__ID__'}) }}";
        window.LISTING_DELETE_PATH  = "{{ path('listing_projects_detete', {id: '__ID__'}) }}";
        window.IS_ADMIN             = {{ is_granted('ROLE_ADMIN') ? 'true' : 'false' }};
    </script>
    <script src="{{ asset('assets/js/listing_projects.js') }}"></script>
{% endblock %}

