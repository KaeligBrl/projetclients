{% extends 'base.html.twig' %}

{% block title %}Identité visuelle en cours - {% block title_base %}{{ parent() }}{% endblock %}{% endblock %}

{% block content %}

	<h1 class="text-center color-white">Identité visuelle en cours</h1>
	<div class="mb-3"></div>
	<div class="separator"></div>
	<div class="row">
		<div class="col padding-mobile">
			{% if is_granted('IS_AUTHENTICATED_FULLY') and is_granted('ROLE_COMPTA') %}
				{% if projects is empty %}
					<p class="text-center color-white mt-2">Aucun projet d'identité visuelle n'a encore été ajouté</p>
					{% if is_granted('ROLE_ADMIN') %}
					<p class="text-center color-white mt-2">Ajouter un projet <a href="{{ path('visual_identity_add') }}">ici</a></p>
					{% endif %}
				{% else %}
					{% if is_granted('ROLE_ADMIN') %}
					<div class="d-flex flex-row-reverse">
						<a href="{{ path('visual_identity_add') }}" title="Ajouter un projet" type="button" class="btn mb-3">
							<i class="color-white fas fa-plus-circle"></i>
						</a>
					</div>
					{% endif %}
					<table class="table mb-5 table-bordered">
						<thead class="bg-blue-dark-light table-borderless">
							<tr>
								<th class="color-yellow text-bold" scope="col">Nom du<br>client</th>
								<th class="color-yellow text-bold" scope="col">Brief<br>client</th>
								<th class="color-yellow text-bold" scope="col">Prise<br>de rdv</th>
								<th class="color-yellow text-bold" scope="col">Présentation</th>
								<th class="color-yellow text-bold" scope="col">Retravail</th>
								<th class="color-yellow text-bold" scope="col">Validation</th>
								<th class="color-yellow text-bold" scope="col">Déclinaisons</th>
								<th class="color-yellow text-bold" scope="col">Fichiers<br>livrés</th>
								{% if is_granted('ROLE_ADMIN') %}
								<th class="color-yellow text-bold" scope="col">Action</th>
								{% endif %}
							</tr>
						</thead>
						<tbody class="bg-blue-dark">
							{% for project in projects %}
								{% if project.finished == false %}
									<tr class="form-switch">
										<td class="color-white text-bold">{{ project.customer }}</td>
										<td class="text-center">
											<input type="checkbox" class="vi-customer-brief form-check-input"
												{{ project.customerBrief ? 'checked' : '' }}
												data-vi-customer-brief="{{ project.id }}">
										</td>
										<td class="text-center">
											<input type="checkbox" class="vi-appointment form-check-input"
												{{ project.appointmentScheduled ? 'checked' : '' }}
												data-vi-appointment="{{ project.id }}">
										</td>
										<td class="text-center">
											<input type="checkbox" class="vi-presentation form-check-input"
												{{ project.presentationDone ? 'checked' : '' }}
												data-vi-presentation="{{ project.id }}">
										</td>
										<td class="text-center">
											<input type="checkbox" class="vi-rework form-check-input"
												{{ project.reworkDone ? 'checked' : '' }}
												data-vi-rework="{{ project.id }}">
										</td>
										<td class="text-center">
											<input type="checkbox" class="vi-validated form-check-input"
												{{ project.validated ? 'checked' : '' }}
												data-vi-validated="{{ project.id }}">
										</td>
										<td class="text-center">
											<input type="checkbox" class="vi-declinations form-check-input"
												{{ project.declinationsDone ? 'checked' : '' }}
												data-vi-declinations="{{ project.id }}">
										</td>
										<td class="text-center">
											<input type="checkbox" class="vi-files-delivered form-check-input"
												{{ project.filesDelivered ? 'checked' : '' }}
												data-vi-files-delivered="{{ project.id }}">
										</td>
										{% if is_granted('ROLE_ADMIN') %}
										<td>
											<a href="{{ path('visual_identity_to_finished', {id: project.id}) }}" title="Passer en projet fini"><i class="color-white fas fa-chevron-right"></i></a>
											<span class="color-white">|</span>
											<a href="{{ path('visual_identity_delete', {id: project.id}) }}" data-confirm="Supprimer ce projet ?" title="Supprimer"><i class="color-white fas fa-trash"></i></a>
										</td>
										{% endif %}
									</tr>
								{% endif %}
							{% endfor %}
						</tbody>
					</table>
				{% endif %}
			{% endif %}
		</div>
	</div>

{% endblock %}
