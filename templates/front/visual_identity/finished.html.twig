{% extends 'base.html.twig' %}

{% block title %}Identité visuelle — Projets finis - {% block title_base %}{{ parent() }}{% endblock %}{% endblock %}

{% block content %}

	<h1 class="text-center color-white">Identité visuelle — Projets finis</h1>
	<div class="mb-3"></div>
	<div class="separator"></div>
	<div class="row">
		<div class="col padding-mobile mt-3">
			{% if projects is empty %}
				<p class="text-center color-white mt-2">Aucun projet d'identité visuelle fini pour l'instant</p>
			{% else %}
				<table class="table mb-5 table-bordered">
					<thead class="bg-blue-dark-light table-borderless">
						<tr>
							<th class="color-yellow text-bold" scope="col">Nom du client</th>
							<th class="color-yellow text-bold" scope="col">Action</th>
						</tr>
					</thead>
					<tbody class="bg-blue-dark">
						{% for project in projects %}
							<tr>
								<td class="color-white text-bold">{{ project.customer }}</td>
								<td>
									<a href="{{ path('visual_identity_to_current', {id: project.id}) }}" title="Repasser en cours"><i class="color-white fas fa-chevron-left"></i></a>
									<span class="color-white">|</span>
									<a href="{{ path('visual_identity_delete', {id: project.id}) }}" onclick="return confirm('Supprimer ce projet ?')" title="Supprimer"><i class="color-white fas fa-trash"></i></a>
								</td>
							</tr>
						{% endfor %}
					</tbody>
				</table>
			{% endif %}
		</div>
	</div>

{% endblock %}
