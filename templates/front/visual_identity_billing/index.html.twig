{% extends 'base.html.twig' %}

{% block title %}Facturation identité visuelle - {% block title_base %}{{ parent() }}{% endblock %}{% endblock %}

{% block content %}

	<h1 class="text-center color-white">Facturation identité visuelle</h1>
	<div class="mb-3"></div>
	<div class="separator"></div>
	{% if hasUnavailableSteps %}
		<div class="alert alert-warning mt-3 mb-3" role="alert">
			Certaines cases sont grisées car aucun email destinataire n'est configuré dans Paramètres > Emails facturation.
		</div>
	{% endif %}
	<div class="alert mt-3 mb-3 billing-info-alert" role="alert">
		<i class="fas fa-info-circle me-1 billing-info-icon"></i>
		{% if is_granted('ROLE_ADMIN') %}
			Les colonnes <strong>Facturé</strong> et <strong>Payé</strong> sont à votre charge. Vous pouvez cocher les cases au fur et à mesure de l'avancement de la facturation.
		{% else %}
			<strong>Workflow :</strong> Shebam coche <strong>Demander la facturation</strong> → vous pouvez ensuite cocher <strong>Facturé</strong> puis <strong>Payé</strong>.
			<br><small class="billing-info-note">Les cases grisées ne sont pas encore disponibles — attendez la demande de Shebam.
</small>
		{% endif %}
	</div>
	<div class="row">
		<div class="col padding-mobile">
			{% if is_granted('IS_AUTHENTICATED_FULLY') and is_granted('ROLE_COMPTA') %}
				{% if billings is empty %}
					<p class="text-center color-white mt-2">Aucun projet trouvé.</p>
				{% else %}
					<div class="table-responsive">
				<table class="table mb-5 table-bordered billing-table billing-table--vi-front">
						<thead class="bg-blue-dark-light table-borderless">
							<tr>
								<th class="color-yellow text-bold" rowspan="2" scope="col">Client</th>
								<th class="color-yellow text-bold text-center" colspan="3">Acompte / Devis signé</th>
							<th class="color-yellow text-bold text-center" colspan="3">Validation du logo</th>
							<th class="color-yellow text-bold text-center" colspan="3">Charte graphique / Support / Solde restant</th>
						</tr>
						<tr class="billing-subhead-row">
							<th class="color-white text-center billing-subhead" title="Cocher déclenche un email au client">Demander la facturation</th>
							<th class="color-yellow text-center billing-subhead">Facturé</th>
							<th class="color-yellow text-center billing-subhead">Payé</th>
								<th class="color-white text-center billing-subhead" title="Cocher déclenche un email au client">Demander la facturation</th>
								<th class="color-yellow text-center billing-subhead">Facturé</th>
								<th class="color-yellow text-center billing-subhead">Payé</th>
								<th class="color-white text-center billing-subhead" title="Cocher déclenche un email au client">Demander la facturation</th>
								<th class="color-yellow text-center billing-subhead">Facturé</th>
								<th class="color-yellow text-center billing-subhead">Payé</th>
							</tr>
						</thead>
						<tbody class="bg-blue-dark">
							{% for billing in billings %}
								<tr>
									<td class="color-white text-bold align-middle billing-client-cell">{{ billing.visualIdentityProject.customer }}</td>
									{# Acompte #}
									<td class="text-center align-middle">
										<input type="checkbox"
											class="vi-billing-deposit form-check-input"
											{{ billing.deposit ? 'checked' : '' }}									{{ not is_granted('ROLE_ADMIN') ? 'disabled' : '' }}											data-mail-enabled="{{ mailEnabled.deposit ? '1' : '0' }}"
											data-vi-billing-deposit="{{ billing.id }}">
									</td>
									<td class="text-center align-middle">
										<input type="checkbox" class="vi-billing-deposit-invoiced form-check-input" {{ billing.depositInvoiced ? 'checked' : '' }} data-vi-billing-deposit-invoiced="{{ billing.id }}">
									</td>
									<td class="text-center align-middle">
										<input type="checkbox"
											class="vi-billing-deposit-paid form-check-input"
											{{ billing.depositPaid ? 'checked' : '' }}
											{{ (not is_granted('ROLE_ADMIN') or not billing.depositInvoiced) ? 'disabled' : '' }}
											data-role-required="admin"
											data-vi-billing-deposit-paid="{{ billing.id }}">
									</td>

									{# Validation du logo #}
									<td class="text-center align-middle">
										<input type="checkbox"
											class="vi-billing-logo form-check-input"
											{{ billing.logoValidation ? 'checked' : '' }}
											{{ not is_granted('ROLE_ADMIN') ? 'disabled' : '' }}
											data-mail-enabled="{{ mailEnabled.logo_validation is defined ? (mailEnabled.logo_validation ? '1' : '0') : '1' }}"
											data-vi-billing-logo="{{ billing.id }}">
									</td>
									<td class="text-center align-middle">
										<input type="checkbox" class="vi-billing-logo-invoiced form-check-input" {{ billing.logoValidationInvoiced ? 'checked' : '' }} data-vi-billing-logo-invoiced="{{ billing.id }}">
									</td>
									<td class="text-center align-middle">
										<input type="checkbox"
											class="vi-billing-logo-paid form-check-input"
											{{ billing.logoValidationPaid ? 'checked' : '' }}
											{{ (not is_granted('ROLE_ADMIN') or not billing.logoValidationInvoiced) ? 'disabled' : '' }}
											data-role-required="admin"
											data-vi-billing-logo-paid="{{ billing.id }}">
									</td>

									{# Envoi admin #}
									<td class="text-center align-middle">
										<input type="checkbox"
											class="vi-billing-status form-check-input"
											{{ billing.status ? 'checked' : '' }}									{{ not is_granted('ROLE_ADMIN') ? 'disabled' : '' }}											data-mail-enabled="{{ mailEnabled.status ? '1' : '0' }}"
											data-vi-billing-status="{{ billing.id }}">
									</td>
									<td class="text-center align-middle">
										<input type="checkbox" class="vi-billing-status-invoiced form-check-input" {{ billing.statusInvoiced ? 'checked' : '' }} data-vi-billing-status-invoiced="{{ billing.id }}">
									</td>
									<td class="text-center align-middle">
										<input type="checkbox"
											class="vi-billing-status-paid form-check-input"
											{{ billing.statusPaid ? 'checked' : '' }}
											{{ (not is_granted('ROLE_ADMIN') or not billing.statusInvoiced) ? 'disabled' : '' }}
											data-role-required="admin"
											data-vi-billing-status-paid="{{ billing.id }}">
									</td>
								</tr>
							{% endfor %}
						</tbody>
					</table>
				</div>
				{% endif %}
			{% endif %}
		</div>
	</div>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('assets/js/visual_identity_billing_checkbox.js') }}"></script>
{% endblock %}


