<!doctype html>
<html lang="{{ app.request.locale }}">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>{%  block title %}{% block title_base %}Projets clients{% endblock %}{% endblock %}</title>

    {% block stylesheets %}
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@5.15.4/css/all.min.css" crossorigin="anonymous">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" crossorigin="anonymous">
        <link href="{{ asset('assets/css/root.css') }}" rel="stylesheet">
        <link href="{{ asset('assets/css/front/custom.css') }}" rel="stylesheet">
        <link href="{{ asset('assets/css/motdepasse.css') }}" rel="stylesheet">
        <link href="{{ asset('assets/css/front/responsive.css') }}" rel="stylesheet">
    {% endblock %}
</head>
<body>
    <header>
    <nav class="navbar-expand-lg navbar-dark pr-2 nav-topbar">
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavTopBar" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="" role="button"><i class="fa fa-bars nav-toggler-icon" aria-hidden="true"></i></span>
        </button>
            <div class="navbar-collapse collapse w-100 order-3 dual-collapse2" id="navbarNavTopBar">
                <ul class="navbar-nav ml-auto">
                    <li class="nav-item">
                        <a class="nav-link nav-topbar-link nav-topbar-link-accent" href="https://todo.shebam.fr/" target="new">&nbsp; Liste des tâches</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link nav-topbar-link" href="{{ path('app_logout') }}"><i class="fas fa-unlock"></i>&nbsp; Déconnexion</a>
                    </li>
                </ul>
            </div>
        </nav>

        <nav class="navbar navbar-expand-lg bg-blue-dark">
            <a href="{{ path('website_project') }}">
		        <img class="d-block mx-auto" src="{{ asset('/assets/images/logo-projet-clients-nav.png') }}" alt="Logo de connexion To Do List">
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="" role="button" ><i class="fa fa-bars nav-toggler-icon" aria-hidden="true"></i></span>
            </button>
            <div class="collapse navbar-collapse bg-blue-dark p-4" id="navbarNav">
                <ul class="navbar-nav me-auto">
                {% if app.user %}
                    {% if is_granted('ROLE_ADMIN') %}
                            <li class="nav-item dropdown"> 
                                <a class="
                                    {% if app.request.attributes.get('_route') starts with 'website_project' %}active{% endif %}
                                    {% if app.request.attributes.get('_route') starts with 'project_modify' %}active{% endif %}
                                    {% if app.request.attributes.get('_route') == 'website_project_add' %}active{% endif %}
                                    {% if app.request.attributes.get('_route') starts with 'website_projects_finished' %}active{% endif %}
                                    navbar-text text-uppercase text-border dropdown-toggle"
                                    href="#" id="navDropdownSitesWeb" role="button"
                                    data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                    SITES WEB
                                </a>
                                <div class="dropdown-menu dropdown-menu-dark" aria-labelledby="navDropdownSitesWeb">
                                    <a class="dropdown-item {% if app.request.attributes.get('_route') == 'website_project' %}active{% endif %}" href="{{ path('website_project') }}">
                                        <i class="fas fa-spinner fa-fw mr-1"></i> En cours
                                    </a>
                                    <a class="dropdown-item {% if app.request.attributes.get('_route') starts with 'website_projects_finished' %}active{% endif %}" href="{{ path('website_projects_finished') }}">
                                        <i class="fas fa-check-circle fa-fw mr-1"></i> Projets finis
                                    </a>
                                    <a class="dropdown-item 
                                        {% if app.request.attributes.get('_route') starts with 'listing_projects' %}active{% endif %}
                                        navbar-text" href="{{ path('listing_projects') }}">Liste des sites
                                    </a>
                                    <div class="dropdown-divider"></div>
                                    <a class="dropdown-item {% if app.request.attributes.get('_route') == 'website_project_add' %}active{% endif %}" href="{{ path('website_project_add') }}">
                                        <i class="fas fa-plus-circle fa-fw mr-1"></i> Ajouter un projet
                                    </a>
                                </div>
                            </li>
                    {% endif %}
                {% endif %}
                </ul>
                <ul class="navbar-nav ms-auto">
                {% if app.user %}
                    {% if is_granted('ROLE_ADMIN') %}
                            <li>
                                <a class="{% if app.request.attributes.get('_route') starts with 'list_customer' %}active{% endif %} navbar-text text-uppercase" title="Aller sur l'administration" href="{{ path('list_customer') }}">Administration</a>
                            </li>
                    {% endif %}
                {% endif %}
                </ul>
            </div>
        </nav>
            
    </header>

    <main role="main">
        <div class="container-fluid layout-main-offset">
            {% block content %}{% endblock %}
        </div>
    </main>

{% block javascripts %}
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.6.0/dist/jquery.min.js" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-MrcW6ZMFYlzcLA8Nl+NtUVF0sA7MsXsP1UyJoMp4YLEuNSfAP+JcXn/tWtIaxVXM" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js" crossorigin="anonymous"></script>
    <script src="{{ asset('assets/js/bootstrap-table.js') }}"></script>
    <script src="{{ asset('assets/js/checkbox.js') }}"></script>
{% endblock %}

</body>
</html>
