{% extends 'back/base_admin.html.twig' %}
{% block page_title %}Équipe{% endblock %}

{% block title %}Équipe - {% block title_base %}{{ parent() }}{% endblock %}{% endblock %}

{% block content %}

	<h1 class="text-center color-white">Équipe</h1>
	<div class="mb-3"></div>
	<div class="separator"></div>
	<div class="d-flex flex-row-reverse">
		<a href="{{ path('user_add') }}" title="Ajouter un utilisateur" type="button" class="btn mb-3">
			<i class="color-white fas fa-plus-circle"></i>
		</a>
	</div>
	<table class="table table-bordered">
		<thead class="bg-blue-dark-light table-borderless">
			<tr>
				<th class="color-yellow" scope="col">Nom</th>
				<th class="color-yellow" scope="col">Prénom</th>
				<th class="color-yellow" scope="col">Adresse Mail</th>
				<th class="color-yellow" scope="col">Rôle</th>
				<th class="color-yellow" scope="col">Action</th>
			</tr>
		</thead>
		<tbody class="bg-blue-dark table-borderless">
			{% for user in user %}
				<tr>
					<td class="color-white text-bold">{{ user.lastname }}</td>
					<td class="color-white text-bold">{{ user.firstname }}</td>
					<td class="color-white text-bold">{{ user.email }}</td>
					<td class="color-white text-bold">
						{% for role in user.roles %}
							{% if role == "ROLE_USER" %}
								Utilisateur
							{% elseif role == "ROLE_PRO" %}
								Entreprise
							{% elseif role == "ROLE_ADMIN" %}
								Administrateur
							{% endif %}
						{% endfor %}
					</td>
					<td>
						<a class="color-yellow" href="{{ path('user_modify', {id: user.id}) }}"><i class="fas fa-cog"></i></a>
						&nbsp;
						<a class="color-yellow" href="{{ path('user_delete', {id: user.id}) }}" onclick="return confirm('Supprimer cet utilisateur ?')"><i class="fas fa-trash"></i></a>
					</td>
				</tr>
			{% endfor %}
		</tbody>
	</table>

{% endblock %}

