{% extends 'back/base_admin.html.twig' %}
{% block page_title %}Ajouter un utilisateur{% endblock %}

{% block title %}Ajouter un utilisateur - {% block title_base %}{{ parent() }}{% endblock %}{% endblock %}

{% block content %}
    <div class="form-back">
        {{ form_start(form_user_add) }}
        <div class="form-group">
            {{ form_row(form_user_add.firstname) }}
            {{ form_row(form_user_add.lastname) }}
            {{ form_row(form_user_add.email) }}
            {{ form_row(form_user_add.password) }}
            {{ form_row(form_user_add.roles) }}
            {{ form_row(form_user_add.submit) }}
        </div>
        {{ form_end(form_user_add) }}
    </div>
{% endblock %}


