{% extends 'back/base_admin.html.twig' %}
{% block page_title %}Ajouter un filtre type de site{% endblock %}
{% block title %}Ajouter un filtre type de site - {% block title_base %}{{ parent() }}{% endblock %}{% endblock %}

{% block content %}
    <h1 class="color-white mb-3">Ajouter un filtre</h1>
    <div class="separator mb-4"></div>
    {% if notification %}
        <div class="form-success text-center text-bold mb-3">
            {{ notification }}<br>
            <a href="{{ path('filters_websites_types') }}">Retourner à la liste des filtres</a>
        </div>
    {% endif %}
    <div class="form-general">
        <div class="form-group">
            {{ form_start(form_filter_website_type_add) }}
                {{ form_row(form_filter_website_type_add.nameWebsites) }}
                {{ form_row(form_filter_website_type_add.submit) }}
            {{ form_end(form_filter_website_type_add) }}
        </div>
    </div>
{% endblock %}