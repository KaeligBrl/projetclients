{% extends 'back/base_admin.html.twig' %}
{% block page_title %}Modifier un filtre type de site{% endblock %}
{% block title %}Modifier le filtre - {% block title_base %}{{ parent() }}{% endblock %}{% endblock %}

{% block content %}
    {% if notification %}
        <div class="form-success text-center text-bold mb-3">
            {{ notification }}<br>
            <a href="{{ path('filters_websites_types') }}">Retourner sur la liste des filtres</a>
        </div>
    {% endif %}
    <div class="form-back">
        <h1 class="form-title text-center color-white">Modification du filtre <br><i class="fas fa-arrow-right"></i> {{ filterWebsite.nameWebsites }}</h1>
        <div class="separator mb-3"></div>
        {{ form_start(form_filter_website_type_modify) }}
            {{ form_row(form_filter_website_type_modify.nameWebsites) }}
            {{ form_row(form_filter_website_type_modify.submit) }}
        {{ form_end(form_filter_website_type_modify) }}
    </div>
{% endblock %}