{% extends 'back/base_admin.html.twig' %}
{% block page_title %}Paramètres{% endblock %}
{% block title %}Paramètres - {% block title_base %}{{ parent() }}{% endblock %}{% endblock %}

{% block content %}

    <h1 class="color-white mb-3 text-center">Paramètres</h1>
    <div class="separator mb-4"></div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}

    {# Onglets — style initial rendu côté serveur, JS ne fait que le permuter #}
    <ul class="nav mb-4 settings-tab-nav" id="settingsTabNav">
        <li class="nav-item">
            <button type="button" data-tab="website"
                    class="settings-tab-btn{% if activeTab == 'website' %} settings-tab-btn--active{% endif %}">
                <i class="fas fa-globe me-1"></i> Sites web
            </button>
        </li>
        <li class="nav-item">
            <button type="button" data-tab="visual_identity"
                    class="settings-tab-btn{% if activeTab == 'visual_identity' %} settings-tab-btn--active{% endif %}">
                <i class="fas fa-paint-brush me-1"></i> Identité visuelle
            </button>
        </li>
    </ul>

    {# Bandeau variables disponibles #}
    <div class="mb-4 px-3 py-2 rounded d-flex align-items-center gap-3 flex-wrap settings-vars-banner">
        <span class="color-yellow fw-bold settings-vars-title"><i class="fas fa-info-circle me-1"></i>Variables disponibles dans sujet &amp; message :</span>
                
        <code class="settings-var-token">{client}</code>
        <span class="color-white settings-var-text">entreprise</span>
        <code class="settings-var-token">{section}</code>
        <span class="color-white settings-var-text">section du projet</span>
        <span class="color-white opacity-50 mx-1">|</span>
        <span class="color-yellow fw-bold settings-var-text">Acompte uniquement :</span>
        <code class="settings-var-token">{firstname}</code>
        <span class="color-white settings-var-text">prénom</span>
        <code class="settings-var-token">{lastname}</code>
        <span class="color-white settings-var-text">nom</span>
        <code class="settings-var-token">{address}</code>
        <span class="color-white settings-var-text">adresse</span>
        <code class="settings-var-token">{tva}</code>
        <span class="color-white settings-var-text">n° TVA</span>
    </div>

    {# ── Panneau Sites web ── #}
    <div id="tab-website" class="settings-tab-panel{% if activeTab != 'website' %} is-hidden{% endif %}">
        {% set wsLookup = {} %}
        {% for s in websiteSettings %}{% set wsLookup = wsLookup|merge({(s.checkboxKey): s}) %}{% endfor %}
        {% set wsGroups = [
            {id: 'deposit',  label: '1. Acompte / Devis signé',           icon: 'fas fa-handshake',       keys: ['deposit',            'deposit_invoiced',            'deposit_paid']},
            {id: 'mockup',   label: '2. Maquettes envoyées',               icon: 'fas fa-drafting-compass', keys: ['mockup_sent',         'mockup_sent_invoiced',         'mockup_sent_paid']},
            {id: 'training', label: '3. Formation / Mise en ligne / Solde',icon: 'fas fa-graduation-cap',  keys: ['onboarding_training', 'onboarding_training_invoiced', 'onboarding_training_paid']},
            {id: 'status',   label: 'Transmis compta',                     icon: 'fas fa-paper-plane',     keys: ['status',              'status_invoiced',              'status_paid']},
            {id: 'global',   label: 'Facturation globale',                 icon: 'fas fa-globe',           keys: ['invoiced',            'paid']},
        ] %}
        <ul class="nav mb-4 settings-metier-tab-nav" data-section="website">
            {% for group in wsGroups %}
            <li class="nav-item">
                <button type="button"
                        class="settings-metier-btn{% if loop.first %} settings-metier-btn--active{% endif %}"
                        data-section="website" data-step="{{ group.id }}">
                    <i class="{{ group.icon }} me-1"></i>{{ group.label }}
                </button>
            </li>
            {% endfor %}
        </ul>
        {% for group in wsGroups %}
        <div class="settings-metier-panel{% if not loop.first %} is-hidden{% endif %}" data-section="website" data-step="{{ group.id }}">
            {% for key in group.keys %}
                {% if wsLookup[key] is defined %}
                    {% set aud = (key ends with '_invoiced' or key ends with '_paid') ? 'equipe' : 'compta' %}
                    {{ _self.settingCard(wsLookup[key], 'website', aud) }}
                {% endif %}
            {% endfor %}
        </div>
        {% endfor %}
    </div>

    {# ── Panneau Identité visuelle ── #}
    <div id="tab-visual_identity" class="settings-tab-panel{% if activeTab != 'visual_identity' %} is-hidden{% endif %}">
        {% set viLookup = {} %}
        {% for s in visualIdentitySettings %}{% set viLookup = viLookup|merge({(s.checkboxKey): s}) %}{% endfor %}
        {% set viGroups = [
            {id: 'deposit', label: '1. Acompte / Devis signé',           icon: 'fas fa-handshake',       keys: ['deposit',          'deposit_invoiced',          'deposit_paid']},
            {id: 'logo',    label: '2. Validation du logo',               icon: 'fas fa-paint-brush',     keys: ['logo_validation',  'logo_validation_invoiced',  'logo_validation_paid']},
            {id: 'status',  label: '3. Charte graphique / Solde restant', icon: 'fas fa-drafting-compass', keys: ['status',           'status_invoiced',           'status_paid']},
            {id: 'global',  label: 'Facturation globale',                 icon: 'fas fa-globe',           keys: ['invoiced',         'paid']},
        ] %}
        <ul class="nav mb-4 settings-metier-tab-nav" data-section="visual_identity">
            {% for group in viGroups %}
            <li class="nav-item">
                <button type="button"
                        class="settings-metier-btn{% if loop.first %} settings-metier-btn--active{% endif %}"
                        data-section="visual_identity" data-step="{{ group.id }}">
                    <i class="{{ group.icon }} me-1"></i>{{ group.label }}
                </button>
            </li>
            {% endfor %}
        </ul>
        {% for group in viGroups %}
        <div class="settings-metier-panel{% if not loop.first %} is-hidden{% endif %}" data-section="visual_identity" data-step="{{ group.id }}">
            {% for key in group.keys %}
                {% if viLookup[key] is defined %}
                    {% set aud = (key ends with '_invoiced' or key ends with '_paid') ? 'equipe' : 'compta' %}
                    {{ _self.settingCard(viLookup[key], 'visual_identity', aud) }}
                {% endif %}
            {% endfor %}
        </div>
        {% endfor %}
    </div>

{% endblock %}

{# ── Macro carte formulaire ── #}
{% macro settingCard(setting, tab, audience) %}
    {% set labelsFr = {
        'website': {
            'deposit': "Email déclenché par l'équipe à la signature",
            'mockup_sent': "Email déclenché à l'envoi des maquettes",
            'onboarding_training': "Email déclenché à la formation / mise en ligne",
            'status': "Email déclenché à la transmission compta",
            'invoiced': "Email de confirmation de facturation globale",
            'paid': "Email de confirmation de paiement global",
            'deposit_invoiced': "Email compta → équipe : acompte facturé",
            'deposit_paid': "Email compta → équipe : acompte payé",
            'mockup_sent_invoiced': "Email compta → équipe : maquettes facturées",
            'mockup_sent_paid': "Email compta → équipe : maquettes payées",
            'onboarding_training_invoiced': "Email compta → équipe : formation facturée",
            'onboarding_training_paid': "Email compta → équipe : formation payée",
            'status_invoiced': "Email compta → équipe : solde facturé",
            'status_paid': "Email compta → équipe : solde payé"
        },
        'visual_identity': {
            'deposit': "Email déclenché par l'équipe à la signature",
            'logo_validation': "Email déclenché à la demande de validation du logo",
            'status': "Email déclenché à la demande charte / solde",
            'invoiced': "Email de confirmation de facturation globale",
            'paid': "Email de confirmation de paiement global",
            'deposit_invoiced': "Email compta → équipe : acompte facturé",
            'deposit_paid': "Email compta → équipe : acompte payé",
            'logo_validation_invoiced': "Email compta → équipe : validation du logo facturée",
            'logo_validation_paid': "Email compta → équipe : validation du logo payée",
            'status_invoiced': "Email compta → équipe : charte / solde facturé",
            'status_paid': "Email compta → équipe : charte / solde payé"
        }
    } %}
    {% set desc = labelsFr[tab][setting.checkboxKey] ?? (setting.checkboxKey|replace({'_': ' '})|capitalize) %}
    <div class="mb-3 rounded overflow-hidden settings-card">
        <div class="d-flex align-items-center gap-2 px-3 py-2 settings-card-header">
            <i class="fas fa-envelope color-yellow"></i>
            <span class="color-white settings-card-header-title flex-grow-1">{{ desc }}</span>
            {% if audience == 'compta' %}
                <span class="settings-audience-badge settings-audience-badge--compta">
                    <i class="fas fa-file-invoice-dollar me-1"></i>→ Compta
                </span>
            {% else %}
                <span class="settings-audience-badge settings-audience-badge--equipe">
                    <i class="fas fa-user-shield me-1"></i>→ Équipe
                </span>
            {% endif %}
            {% if setting.recipientEmail %}
                <span class="settings-status settings-status--configured ms-1">
                    <i class="fas fa-check-circle me-1 settings-icon-ok"></i>Configuré
                </span>
            {% else %}
                <span class="settings-status settings-status--missing ms-1">
                    <i class="fas fa-exclamation-circle me-1"></i>Non configuré
                </span>
            {% endif %}
        </div>
        <div class="p-3 settings-card-body">
            <form method="post" action="{{ path('admin_settings') }}">
                <input type="hidden" name="id" value="{{ setting.id }}">
                <input type="hidden" name="tab" value="{{ tab }}">
                <div class="row g-3">
                    <div class="col-12 col-md-6">
                        <label class="color-white mb-1 d-block settings-field-label">
                            <i class="fas fa-at me-1 color-yellow"></i>Adresse email destinataire
                        </label>
                        <input type="email" name="recipientEmail" class="form-control settings-form-control"
                               value="{{ setting.recipientEmail ?? '' }}"
                               placeholder="ex: admin@monentreprise.fr">
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="color-white mb-1 d-block settings-field-label">
                            <i class="fas fa-tag me-1 color-yellow"></i>Sujet de l'email
                        </label>
                        <input type="text" name="subject" class="form-control settings-form-control"
                               value="{{ setting.subject ?? '' }}"
                               placeholder="ex: Acompte reçu — {client}">
                    </div>
                    <div class="col-12">
                        <label class="color-white mb-1 d-block settings-field-label">
                            <i class="fas fa-align-left me-1 color-yellow"></i>Corps du message
                        </label>
                        <textarea name="messageBody" class="form-control settings-form-control" rows="4"
                                  placeholder="ex: Bonjour,&#10;L'acompte pour le projet {client} ({section}) a été reçu.">{{ setting.messageBody ?? '' }}</textarea>
                    </div>
                    <div class="col-12 text-end">
                        <button type="submit" class="btn btn-sm settings-save-btn">
                            <i class="fas fa-save me-1"></i> Sauvegarder
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
{% endmacro %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('assets/js/settings-tabs.js') }}"></script>
{% endblock %}
