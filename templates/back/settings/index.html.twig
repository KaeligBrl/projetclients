{% extends 'back/base_admin.html.twig' %}
{% block page_title %}Paramètres{% endblock %}
{% block title %}Paramètres - {% block title_base %}{{ parent() }}{% endblock %}{% endblock %}

{% block content %}

    <h1 class="color-white mb-3 text-center">Paramètres</h1>
    <div class="separator mb-4"></div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}

    {# Onglets — style initial rendu côté serveur, JS ne fait que le permuter #}
    <ul class="nav mb-4 settings-tab-nav" id="settingsTabNav" data-initial-mail-tab="{{ activeMailTab|default('compta') }}">
        <li class="nav-item">
            <button type="button" data-tab="website"
                    class="settings-tab-btn{% if activeTab == 'website' %} settings-tab-btn--active{% endif %}">
                <i class="fas fa-globe me-1"></i> Sites web
            </button>
        </li>
        <li class="nav-item">
            <button type="button" data-tab="visual_identity"
                    class="settings-tab-btn{% if activeTab == 'visual_identity' %} settings-tab-btn--active{% endif %}">
                <i class="fas fa-paint-brush me-1"></i> Identité visuelle
            </button>
        </li>
    </ul>

    {# Bandeau variables disponibles #}
    <div class="mb-4 px-3 py-2 rounded d-flex align-items-center gap-3 flex-wrap settings-vars-banner">
        <span class="color-yellow fw-bold settings-vars-title"><i class="fas fa-info-circle me-1"></i>Variables disponibles dans sujet &amp; message :</span>
                
        <code class="settings-var-token">{client}</code>
        <span class="color-white settings-var-text">entreprise</span>
        <code class="settings-var-token">{section}</code>
        <span class="color-white settings-var-text">section du projet</span>
        <span class="color-white opacity-50 mx-1">|</span>
        <span class="color-yellow fw-bold settings-var-text">Acompte uniquement :</span>
        <code class="settings-var-token">{firstname}</code>
        <span class="color-white settings-var-text">prénom</span>
        <code class="settings-var-token">{lastname}</code>
        <span class="color-white settings-var-text">nom</span>
        <code class="settings-var-token">{address}</code>
        <span class="color-white settings-var-text">adresse</span>
        <code class="settings-var-token">{tva}</code>
        <span class="color-white settings-var-text">n° TVA</span>
    </div>

    {# ── Panneau Sites web ── #}
    <div id="tab-website" class="settings-tab-panel{% if activeTab != 'website' %} is-hidden{% endif %}">
        <ul class="nav mb-3 settings-mail-tab-nav">
            <li class="nav-item">
                <button type="button"
                        class="settings-mail-tab-btn"
                        data-parent="website"
                        data-mail-tab="compta">
                    <i class="fas fa-file-invoice-dollar me-1"></i>Email vers compta
                </button>
            </li>
            <li class="nav-item">
                <button type="button"
                        class="settings-mail-tab-btn"
                        data-parent="website"
                        data-mail-tab="admin">
                    <i class="fas fa-user-shield me-1"></i>Email vers équipe
                </button>
            </li>
        </ul>

        <div class="settings-mail-tab-panel{% if activeMailTab != 'compta' %} is-hidden{% endif %}" data-parent="website" data-mail-tab="compta">
            {% for setting in websiteSettings %}
                {% if not (setting.checkboxKey ends with '_invoiced') and not (setting.checkboxKey ends with '_paid') %}
                    {{ _self.settingCard(setting, 'website', activeMailTab) }}
                {% endif %}
            {% endfor %}
        </div>

        <div class="settings-mail-tab-panel{% if activeMailTab != 'admin' %} is-hidden{% endif %}" data-parent="website" data-mail-tab="admin">
            {% for setting in websiteSettings %}
                {% if (setting.checkboxKey ends with '_invoiced') or (setting.checkboxKey ends with '_paid') %}
                    {{ _self.settingCard(setting, 'website', activeMailTab) }}
                {% endif %}
            {% endfor %}
        </div>
    </div>

    {# ── Panneau Identité visuelle ── #}
    <div id="tab-visual_identity" class="settings-tab-panel{% if activeTab != 'visual_identity' %} is-hidden{% endif %}">
        <ul class="nav mb-3 settings-mail-tab-nav">
            <li class="nav-item">
                <button type="button"
                        class="settings-mail-tab-btn"
                        data-parent="visual_identity"
                        data-mail-tab="compta">
                    <i class="fas fa-file-invoice-dollar me-1"></i>Email vers compta
                </button>
            </li>
            <li class="nav-item">
                <button type="button"
                        class="settings-mail-tab-btn"
                        data-parent="visual_identity"
                        data-mail-tab="admin">
                    <i class="fas fa-user-shield me-1"></i>Email vers équipe
                </button>
            </li>
        </ul>

        <div class="settings-mail-tab-panel" data-parent="visual_identity" data-mail-tab="compta">
            {% for setting in visualIdentitySettings %}
                {% if not (setting.checkboxKey ends with '_invoiced') and not (setting.checkboxKey ends with '_paid') %}
                    {{ _self.settingCard(setting, 'visual_identity', activeMailTab) }}
                {% endif %}
            {% endfor %}
        </div>

        <div class="settings-mail-tab-panel" data-parent="visual_identity" data-mail-tab="admin">
            {% for setting in visualIdentitySettings %}
                {% if (setting.checkboxKey ends with '_invoiced') or (setting.checkboxKey ends with '_paid') %}
                    {{ _self.settingCard(setting, 'visual_identity', activeMailTab) }}
                {% endif %}
            {% endfor %}
        </div>
    </div>

{% endblock %}

{# ── Macro carte formulaire ── #}
{% macro settingCard(setting, tab, mailTab) %}
    {% set labelsFr = {
        'website': {
            'deposit': '1. Acompte / Devis signé',
            'mockup_sent': '2. Maquettes envoyées',
            'onboarding_training': '3. Formation de prise / Mise en ligne / Solde restant',
            'status': 'Transmis au service compta',
            'invoiced': 'Facturation globale',
            'paid': 'Paiement global',
            'deposit_invoiced': 'Acompte facturé',
            'deposit_paid': 'Acompte payé',
            'mockup_sent_invoiced': 'Maquettes facturées',
            'mockup_sent_paid': 'Maquettes payées',
            'onboarding_training_invoiced': 'Formation facturée',
            'onboarding_training_paid': 'Formation payée',
            'status_invoiced': 'Solde facturé',
            'status_paid': 'Solde payé'
        },
        'visual_identity': {
            'deposit': '1. Acompte / Devis signé',
            'status': '2. Validation du logo',
            'invoiced': 'Facturation globale',
            'paid': 'Paiement global',
            'status_invoiced': '3. Charte graphique / Support / Solde restant (facturé)',
            'status_paid': '3. Charte graphique / Support / Solde restant (payé)',
            'deposit_invoiced': 'Acompte facturé',
            'deposit_paid': 'Acompte payé'
        }
    } %}
    <div class="mb-1 d-flex align-items-center justify-content-between">
        <span class="color-yellow fw-bold">{{ labelsFr[tab][setting.checkboxKey] ?? (setting.checkboxKey|replace({'_': ' '})|capitalize) }}</span>
    </div>
    <div class="mb-3 rounded overflow-hidden settings-card">
        <div class="d-flex align-items-center px-3 py-2 settings-card-header">
            <i class="fas fa-envelope me-2 color-yellow"></i>
            <span class="color-white settings-card-header-title">Configuration de l'email</span>
            {% if setting.recipientEmail %}
                <span class="ms-auto settings-status settings-status--configured">
                    <i class="fas fa-check-circle me-1 settings-icon-ok"></i>Configuré
                </span>
            {% else %}
                <span class="ms-auto settings-status settings-status--missing">
                    <i class="fas fa-exclamation-circle me-1"></i>Non configuré
                </span>
            {% endif %}
        </div>
        <div class="p-3 settings-card-body">
            <form method="post" action="{{ path('admin_settings') }}">
                <input type="hidden" name="id" value="{{ setting.id }}">
                <input type="hidden" name="tab" value="{{ tab }}">
                <input type="hidden" name="mailTab" value="{{ mailTab }}">
                <div class="row g-3">
                    <div class="col-12 col-md-6">
                        <label class="color-white mb-1 d-block settings-field-label">
                            <i class="fas fa-at me-1 color-yellow"></i>Adresse email destinataire
                        </label>
                        <input type="email" name="recipientEmail" class="form-control settings-form-control"
                               value="{{ setting.recipientEmail ?? '' }}"
                               placeholder="ex: admin@monentreprise.fr">
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="color-white mb-1 d-block settings-field-label">
                            <i class="fas fa-tag me-1 color-yellow"></i>Sujet de l'email
                        </label>
                        <input type="text" name="subject" class="form-control settings-form-control"
                               value="{{ setting.subject ?? '' }}"
                               placeholder="ex: Acompte reçu — {client}">
                    </div>
                    <div class="col-12">
                        <label class="color-white mb-1 d-block settings-field-label">
                            <i class="fas fa-align-left me-1 color-yellow"></i>Corps du message
                        </label>
                        <textarea name="messageBody" class="form-control settings-form-control" rows="4"
                                  placeholder="ex: Bonjour,&#10;L'acompte pour le projet {client} ({section}) a été reçu. Merci de procéder à la facturation.">{{ setting.messageBody ?? '' }}</textarea>
                    </div>
                    <div class="col-12 text-end">
                        <button type="submit" class="btn btn-sm settings-save-btn">
                            <i class="fas fa-save me-1"></i> Sauvegarder
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
{% endmacro %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('assets/js/settings-tabs.js') }}"></script>
{% endblock %}
