{% extends 'back/base_admin.html.twig' %}
{% block page_title %}Facturation admin{% endblock %}
{% block title %}Facturation admin - {% block title_base %}{{ parent() }}{% endblock %}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href="{{ asset('assets/css/back/admin-billing.css') }}" rel="stylesheet">
{% endblock %}

{% block content %}

    <h1 class="color-white mb-3">Facturation — Service admin</h1>
    <div class="separator mb-4"></div>

    <p class="color-white mb-4 admin-billing-intro">
        <i class="fas fa-info-circle me-1 color-yellow"></i>
        Seuls les projets transmis par l'équipe apparaissent ici. Pour chaque étape cochée, marquez-la
        <strong>Facturé</strong> puis <strong>Payé</strong> — un email est envoyé à l'équipe automatiquement.
    </p>

    {# Onglets #}
    <ul class="nav mb-4 admin-billing-tab-nav" id="billingTabNav">
        <li class="nav-item">
            <button type="button" data-tab="website" class="admin-billing-tab-btn{% if app.request.query.get('tab', 'website') == 'website' %} admin-billing-tab-btn--active{% endif %}">
                <i class="fas fa-globe me-1"></i> Sites web
                <span class="ms-1 badge admin-billing-badge">{{ websiteBillings|length }}</span>
            </button>
        </li>
        <li class="nav-item">
            <button type="button" data-tab="vi" class="admin-billing-tab-btn{% if app.request.query.get('tab', 'website') == 'vi' %} admin-billing-tab-btn--active{% endif %}">
                <i class="fas fa-paint-brush me-1"></i> Identité visuelle
                <span class="ms-1 badge admin-billing-badge">{{ viBillings|length }}</span>
            </button>
        </li>
    </ul>

    {# ── Sites web ── #}
    <div id="tab-website" class="admin-billing-panel{% if app.request.query.get('tab', 'website') != 'website' %} is-hidden{% endif %}">
        {% if websiteBillings is empty %}
            <p class="color-white mt-3 admin-billing-empty"><i class="fas fa-check-circle me-1"></i> Aucun projet en attente.</p>
        {% else %}
            <div class="table-responsive">
            <table class="table table-bordered mb-5 admin-billing-table admin-billing-table--website">
                <thead class="admin-billing-head">
                    <tr>
                        <th class="color-yellow align-middle" rowspan="2">Client</th>
                            <th class="color-yellow text-center admin-billing-head-group" colspan="3">Acompte / Devis signé</th>
                            <th class="color-yellow text-center admin-billing-head-group" colspan="3">Maquettes envoyées</th>
                            <th class="color-yellow text-center admin-billing-head-group" colspan="3">Formation de prise / Mise en ligne / Solde restant</th>
                            <th class="color-yellow text-center admin-billing-head-group" colspan="3">Transmis au service compta</th>
                    </tr>
                        <tr class="admin-billing-subhead-row">
                            <th class="color-white text-center admin-billing-subhead admin-billing-subhead--normal">Demandé</th>
                            <th class="color-yellow text-center admin-billing-subhead">Facturé</th>
                            <th class="color-yellow text-center admin-billing-subhead">Payé</th>
                            <th class="color-white text-center admin-billing-subhead admin-billing-subhead--normal">Demandé</th>
                            <th class="color-yellow text-center admin-billing-subhead">Facturé</th>
                            <th class="color-yellow text-center admin-billing-subhead">Payé</th>
                            <th class="color-white text-center admin-billing-subhead admin-billing-subhead--normal">Demandé</th>
                            <th class="color-yellow text-center admin-billing-subhead">Facturé</th>
                            <th class="color-yellow text-center admin-billing-subhead">Payé</th>
                            <th class="color-white text-center admin-billing-subhead admin-billing-subhead--normal">Transmis</th>
                            <th class="color-yellow text-center admin-billing-subhead">Facturé</th>
                            <th class="color-yellow text-center admin-billing-subhead">Payé</th>
                    </tr>
                </thead>
                <tbody class="admin-billing-body">
                    {% for billing in websiteBillings %}
                        <tr>
                            <td class="color-white fw-bold align-middle admin-billing-client">
                                {{ billing.websiteProject.customer }}
                            </td>
                            {# Acompte #}
                            <td class="text-center align-middle">
                                <input type="checkbox" class="form-check-input" {{ billing.deposit ? 'checked' : '' }} disabled title="Demandé par l'équipe">
                            </td>
                            <td class="text-center align-middle">
                                <input type="checkbox" class="form-check-input admin-toggle"
                                    {{ billing.depositInvoiced ? 'checked' : '' }}
                                    {{ not billing.deposit ? 'disabled' : '' }}
                                    data-url="/admin/facturation-sites-web/acompte-facture/{{ billing.id }}">
                            </td>
                                <td class="text-center align-middle">
                                    <input type="checkbox" class="form-check-input admin-toggle"
                                        {{ billing.depositPaid ? 'checked' : '' }}
                                        {{ not billing.depositInvoiced ? 'disabled' : '' }}
                                        data-url="/admin/facturation-sites-web/acompte-paye/{{ billing.id }}">
                                </td>
                            {# Maquette #}
                            <td class="text-center align-middle">
                                <input type="checkbox" class="form-check-input" {{ billing.mockupSent ? 'checked' : '' }} disabled title="Demandé par l'équipe">
                            </td>
                            <td class="text-center align-middle">
                                <input type="checkbox" class="form-check-input admin-toggle"
                                    {{ billing.mockupSentInvoiced ? 'checked' : '' }}
                                    {{ not billing.mockupSent ? 'disabled' : '' }}
                                    data-url="/admin/facturation-sites-web/maquette-facturee/{{ billing.id }}">
                            </td>
                                <td class="text-center align-middle">
                                    <input type="checkbox" class="form-check-input admin-toggle"
                                        {{ billing.mockupSentPaid ? 'checked' : '' }}
                                        {{ not billing.mockupSentInvoiced ? 'disabled' : '' }}
                                        data-url="/admin/facturation-sites-web/maquette-payee/{{ billing.id }}">
                                </td>
                            {# Formation #}
                            <td class="text-center align-middle">
                                <input type="checkbox" class="form-check-input" {{ billing.onboardingTraining ? 'checked' : '' }} disabled title="Demandé par l'équipe">
                            </td>
                            <td class="text-center align-middle">
                                <input type="checkbox" class="form-check-input admin-toggle"
                                    {{ billing.onboardingTrainingInvoiced ? 'checked' : '' }}
                                    {{ not billing.onboardingTraining ? 'disabled' : '' }}
                                    data-url="/admin/facturation-sites-web/formation-facturee/{{ billing.id }}">
                            </td>
                                <td class="text-center align-middle">
                                    <input type="checkbox" class="form-check-input admin-toggle"
                                        {{ billing.onboardingTrainingPaid ? 'checked' : '' }}
                                        {{ not billing.onboardingTrainingInvoiced ? 'disabled' : '' }}
                                        data-url="/admin/facturation-sites-web/formation-payee/{{ billing.id }}">
                                </td>
                            {# Envoi admin #}
                            <td class="text-center align-middle">
                                <input type="checkbox" class="form-check-input" {{ billing.status ? 'checked' : '' }} disabled title="Demandé par l'équipe">
                            </td>
                            <td class="text-center align-middle">
                                <input type="checkbox" class="form-check-input admin-toggle"
                                    {{ billing.statusInvoiced ? 'checked' : '' }}
                                    {{ not billing.status ? 'disabled' : '' }}
                                    data-url="/admin/facturation-sites-web/admin-facture/{{ billing.id }}">
                            </td>
                                <td class="text-center align-middle">
                                    <input type="checkbox" class="form-check-input admin-toggle"
                                        {{ billing.statusPaid ? 'checked' : '' }}
                                        {{ not billing.statusInvoiced ? 'disabled' : '' }}
                                        data-url="/admin/facturation-sites-web/admin-paye/{{ billing.id }}">
                                </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
            </div>
        {% endif %}
    </div>

    {# ── Identité visuelle ── #}
    <div id="tab-vi" class="admin-billing-panel{% if app.request.query.get('tab', 'website') != 'vi' %} is-hidden{% endif %}">
        {% if viBillings is empty %}
            <p class="color-white mt-3 admin-billing-empty"><i class="fas fa-check-circle me-1"></i> Aucun projet en attente.</p>
        {% else %}
            <div class="table-responsive">
            <table class="table table-bordered mb-5 admin-billing-table admin-billing-table--vi">
                <thead class="admin-billing-head">
                    <tr>
                        <th class="color-yellow align-middle" rowspan="2">Client</th>
                        <th class="color-yellow text-center admin-billing-head-group" colspan="3">Acompte / Devis signé</th>
                        <th class="color-yellow text-center admin-billing-head-group" colspan="3">Validation du logo</th>
                        <th class="color-yellow text-center admin-billing-head-group" colspan="3">Charte graphique / Support / Solde restant</th>
                    </tr>
                    <tr class="admin-billing-subhead-row">
                        <th class="color-white text-center admin-billing-subhead admin-billing-subhead--normal">Demandé</th>
                        <th class="color-yellow text-center admin-billing-subhead">Facturé</th>
                        <th class="color-yellow text-center admin-billing-subhead">Payé</th>
                        <th class="color-white text-center admin-billing-subhead admin-billing-subhead--normal">Demandé</th>
                        <th class="color-yellow text-center admin-billing-subhead">Facturé</th>
                        <th class="color-yellow text-center admin-billing-subhead">Payé</th>
                        <th class="color-white text-center admin-billing-subhead admin-billing-subhead--normal">Demandé</th>
                        <th class="color-yellow text-center admin-billing-subhead">Facturé</th>
                        <th class="color-yellow text-center admin-billing-subhead">Payé</th>
                    </tr>
                </thead>
                <tbody class="admin-billing-body">
                    {% for billing in viBillings %}
                        <tr>
                            <td class="color-white fw-bold align-middle admin-billing-client">
                                {{ billing.visualIdentityProject.customer }}
                            </td>
                            {# Acompte #}
                            <td class="text-center align-middle">
                                <input type="checkbox" class="form-check-input" {{ billing.deposit ? 'checked' : '' }} disabled>
                            </td>
                            <td class="text-center align-middle">
                                <input type="checkbox" class="form-check-input admin-toggle"
                                    {{ billing.depositInvoiced ? 'checked' : '' }}
                                    {{ not billing.deposit ? 'disabled' : '' }}
                                    data-url="/admin/facturation-identite-visuelle/acompte-facture/{{ billing.id }}"
                                    data-next-cb-selector="[data-vi-dep-paid-{{ billing.id }}]">
                            </td>
                            <td class="text-center align-middle">
                                <input type="checkbox" class="form-check-input admin-toggle"
                                    {{ billing.depositPaid ? 'checked' : '' }}
                                    {{ not billing.depositInvoiced ? 'disabled' : '' }}
                                    data-vi-dep-paid-{{ billing.id }}="1"
                                    data-url="/admin/facturation-identite-visuelle/acompte-paye/{{ billing.id }}">
                            </td>
                            {# Validation du logo #}
                            <td class="text-center align-middle">
                                <input type="checkbox" class="form-check-input" {{ billing.logoValidation ? 'checked' : '' }} disabled>
                            </td>
                            <td class="text-center align-middle">
                                <input type="checkbox" class="form-check-input admin-toggle"
                                    {{ billing.logoValidationInvoiced ? 'checked' : '' }}
                                    {{ not billing.logoValidation ? 'disabled' : '' }}
                                    data-url="/admin/facturation-identite-visuelle/logo-facture/{{ billing.id }}">
                            </td>
                            <td class="text-center align-middle">
                                <input type="checkbox" class="form-check-input admin-toggle"
                                    {{ billing.logoValidationPaid ? 'checked' : '' }}
                                    {{ not billing.logoValidationInvoiced ? 'disabled' : '' }}
                                    data-url="/admin/facturation-identite-visuelle/logo-paye/{{ billing.id }}">
                            </td>
                            {# Envoi admin #}
                            <td class="text-center align-middle">
                                <input type="checkbox" class="form-check-input" {{ billing.status ? 'checked' : '' }} disabled>
                            </td>
                            <td class="text-center align-middle">
                                <input type="checkbox" class="form-check-input admin-toggle"
                                    {{ billing.statusInvoiced ? 'checked' : '' }}
                                    {{ not billing.status ? 'disabled' : '' }}
                                    data-url="/admin/facturation-identite-visuelle/admin-facture/{{ billing.id }}"
                                    data-next-cb-selector="[data-vi-sta-paid-{{ billing.id }}]">
                            </td>
                            <td class="text-center align-middle">
                                <input type="checkbox" class="form-check-input admin-toggle"
                                    {{ billing.statusPaid ? 'checked' : '' }}
                                    {{ not billing.statusInvoiced ? 'disabled' : '' }}
                                    data-vi-sta-paid-{{ billing.id }}="1"
                                    data-url="/admin/facturation-identite-visuelle/admin-paye/{{ billing.id }}">
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
            </div>
        {% endif %}
    </div>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('assets/js/admin-billing-tabs.js') }}"></script>
{% endblock %}

