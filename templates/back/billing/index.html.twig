{% extends 'back/base_admin.html.twig' %}
{% block page_title %}Facturation admin{% endblock %}
{% block title %}Facturation admin - {% block title_base %}{{ parent() }}{% endblock %}{% endblock %}

{% block content %}

    <h1 class="color-white mb-3">Facturation — Service admin</h1>
    <div class="separator mb-4"></div>

    <p class="color-white mb-4" style="opacity:.8; font-size:.9rem;">
        <i class="fas fa-info-circle me-1 color-yellow"></i>
        Seuls les projets transmis par l'équipe apparaissent ici. Pour chaque étape cochée, marquez-la
        <strong>Facturé</strong> puis <strong>Payé</strong> — un email est envoyé à l'équipe automatiquement.
    </p>

    {# Onglets #}
    <ul class="nav mb-4" id="billingTabNav" style="border-bottom: 2px solid #395c6e; gap:.5rem;">
        <li class="nav-item">
            <button type="button" data-tab="website" class="admin-billing-tab-btn"
                    style="display:inline-block; padding:.5rem 1.25rem; border-radius:.4rem .4rem 0 0; font-weight:600; font-size:.9rem; border:none; cursor:pointer; background:#FFD600; color:#00263A;">
                <i class="fas fa-globe me-1"></i> Sites web
                <span class="ms-1 badge" style="background:#00263A; color:#FFD600;">{{ websiteBillings|length }}</span>
            </button>
        </li>
        <li class="nav-item">
            <button type="button" data-tab="vi" class="admin-billing-tab-btn"
                    style="display:inline-block; padding:.5rem 1.25rem; border-radius:.4rem .4rem 0 0; font-weight:600; font-size:.9rem; border:none; cursor:pointer; background:#023D5C; color:#ffffff;">
                <i class="fas fa-paint-brush me-1"></i> Identité visuelle
                <span class="ms-1 badge" style="background:#001a2e; color:#FFD600;">{{ viBillings|length }}</span>
            </button>
        </li>
    </ul>

    {# ── Sites web ── #}
    <div id="tab-website" class="admin-billing-panel">
        {% if websiteBillings is empty %}
            <p class="color-white mt-3" style="opacity:.6;"><i class="fas fa-check-circle me-1"></i> Aucun projet en attente.</p>
        {% else %}
            <div class="table-responsive">
            <table class="table table-bordered mb-5" style="min-width: 900px;">
                <thead style="background:#023D5C;">
                    <tr>
                        <th class="color-yellow align-middle" rowspan="2">Client</th>
                        <th class="color-yellow text-center" colspan="2" style="border-bottom: 1px solid #FFD600;">Acompte</th>
                        <th class="color-yellow text-center" colspan="2" style="border-bottom: 1px solid #FFD600;">Maquette</th>
                        <th class="color-yellow text-center" colspan="2" style="border-bottom: 1px solid #FFD600;">Formation</th>
                        <th class="color-yellow text-center" colspan="2" style="border-bottom: 1px solid #FFD600;">Envoi admin</th>
                    </tr>
                    <tr style="background:#012d45;">
                        <th class="color-white text-center" style="font-size:.75rem; font-weight:400;">Coché</th>
                        <th class="color-yellow text-center" style="font-size:.75rem;">Facturé</th>
                        <th class="color-white text-center" style="font-size:.75rem; font-weight:400;">Coché</th>
                        <th class="color-yellow text-center" style="font-size:.75rem;">Facturé</th>
                        <th class="color-white text-center" style="font-size:.75rem; font-weight:400;">Coché</th>
                        <th class="color-yellow text-center" style="font-size:.75rem;">Facturé</th>
                        <th class="color-white text-center" style="font-size:.75rem; font-weight:400;">Coché</th>
                        <th class="color-yellow text-center" style="font-size:.75rem;">Facturé</th>
                    </tr>
                </thead>
                <tbody style="background:#00263A;">
                    {% for billing in websiteBillings %}
                        <tr>
                            <td class="color-white fw-bold align-middle" style="white-space:nowrap;">
                                {{ billing.websiteProject.customer }}
                            </td>
                            {# Acompte #}
                            <td class="text-center align-middle">
                                <input type="checkbox" class="form-check-input" {{ billing.deposit ? 'checked' : '' }} disabled title="Coché par l'équipe">
                            </td>
                            <td class="text-center align-middle">
                                <input type="checkbox" class="form-check-input admin-toggle"
                                    {{ billing.depositInvoiced ? 'checked' : '' }}
                                    {{ not billing.deposit ? 'disabled' : '' }}
                                    data-url="/admin/facturation-sites-web/acompte-facture/{{ billing.id }}">
                            </td>
                            {# Maquette #}
                            <td class="text-center align-middle">
                                <input type="checkbox" class="form-check-input" {{ billing.mockupSent ? 'checked' : '' }} disabled title="Coché par l'équipe">
                            </td>
                            <td class="text-center align-middle">
                                <input type="checkbox" class="form-check-input admin-toggle"
                                    {{ billing.mockupSentInvoiced ? 'checked' : '' }}
                                    {{ not billing.mockupSent ? 'disabled' : '' }}
                                    data-url="/admin/facturation-sites-web/maquette-facturee/{{ billing.id }}">
                            </td>
                            {# Formation #}
                            <td class="text-center align-middle">
                                <input type="checkbox" class="form-check-input" {{ billing.onboardingTraining ? 'checked' : '' }} disabled title="Coché par l'équipe">
                            </td>
                            <td class="text-center align-middle">
                                <input type="checkbox" class="form-check-input admin-toggle"
                                    {{ billing.onboardingTrainingInvoiced ? 'checked' : '' }}
                                    {{ not billing.onboardingTraining ? 'disabled' : '' }}
                                    data-url="/admin/facturation-sites-web/formation-facturee/{{ billing.id }}">
                            </td>
                            {# Envoi admin #}
                            <td class="text-center align-middle">
                                <input type="checkbox" class="form-check-input" {{ billing.status ? 'checked' : '' }} disabled title="Coché par l'équipe">
                            </td>
                            <td class="text-center align-middle">
                                <input type="checkbox" class="form-check-input admin-toggle"
                                    {{ billing.statusInvoiced ? 'checked' : '' }}
                                    {{ not billing.status ? 'disabled' : '' }}
                                    data-url="/admin/facturation-sites-web/admin-facture/{{ billing.id }}">
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
            </div>
        {% endif %}
    </div>

    {# ── Identité visuelle ── #}
    <div id="tab-vi" class="admin-billing-panel">
        {% if viBillings is empty %}
            <p class="color-white mt-3" style="opacity:.6;"><i class="fas fa-check-circle me-1"></i> Aucun projet en attente.</p>
        {% else %}
            <div class="table-responsive">
            <table class="table table-bordered mb-5" style="min-width: 500px;">
                <thead style="background:#023D5C;">
                    <tr>
                        <th class="color-yellow align-middle" rowspan="2">Client</th>
                        <th class="color-yellow text-center" colspan="3" style="border-bottom: 1px solid #FFD600;">Acompte</th>
                        <th class="color-yellow text-center" colspan="3" style="border-bottom: 1px solid #FFD600;">Envoi admin</th>
                    </tr>
                    <tr style="background:#012d45;">
                        <th class="color-white text-center" style="font-size:.75rem; font-weight:400;">Coché</th>
                        <th class="color-yellow text-center" style="font-size:.75rem;">Facturé</th>
                        <th class="color-yellow text-center" style="font-size:.75rem;">Payé</th>
                        <th class="color-white text-center" style="font-size:.75rem; font-weight:400;">Coché</th>
                        <th class="color-yellow text-center" style="font-size:.75rem;">Facturé</th>
                        <th class="color-yellow text-center" style="font-size:.75rem;">Payé</th>
                    </tr>
                </thead>
                <tbody style="background:#00263A;">
                    {% for billing in viBillings %}
                        <tr>
                            <td class="color-white fw-bold align-middle" style="white-space:nowrap;">
                                {{ billing.visualIdentityProject.customer }}
                            </td>
                            {# Acompte #}
                            <td class="text-center align-middle">
                                <input type="checkbox" class="form-check-input" {{ billing.deposit ? 'checked' : '' }} disabled>
                            </td>
                            <td class="text-center align-middle">
                                <input type="checkbox" class="form-check-input admin-toggle"
                                    {{ billing.depositInvoiced ? 'checked' : '' }}
                                    {{ not billing.deposit ? 'disabled' : '' }}
                                    data-url="/admin/facturation-identite-visuelle/acompte-facture/{{ billing.id }}"
                                    data-next-cb-selector="[data-vi-dep-paid-{{ billing.id }}]">
                            </td>
                            <td class="text-center align-middle">
                                <input type="checkbox" class="form-check-input admin-toggle"
                                    {{ billing.depositPaid ? 'checked' : '' }}
                                    {{ not billing.depositInvoiced ? 'disabled' : '' }}
                                    data-vi-dep-paid-{{ billing.id }}="1"
                                    data-url="/admin/facturation-identite-visuelle/acompte-paye/{{ billing.id }}">
                            </td>
                            {# Envoi admin #}
                            <td class="text-center align-middle">
                                <input type="checkbox" class="form-check-input" {{ billing.status ? 'checked' : '' }} disabled>
                            </td>
                            <td class="text-center align-middle">
                                <input type="checkbox" class="form-check-input admin-toggle"
                                    {{ billing.statusInvoiced ? 'checked' : '' }}
                                    {{ not billing.status ? 'disabled' : '' }}
                                    data-url="/admin/facturation-identite-visuelle/admin-facture/{{ billing.id }}"
                                    data-next-cb-selector="[data-vi-sta-paid-{{ billing.id }}]">
                            </td>
                            <td class="text-center align-middle">
                                <input type="checkbox" class="form-check-input admin-toggle"
                                    {{ billing.statusPaid ? 'checked' : '' }}
                                    {{ not billing.statusInvoiced ? 'disabled' : '' }}
                                    data-vi-sta-paid-{{ billing.id }}="1"
                                    data-url="/admin/facturation-identite-visuelle/admin-paye/{{ billing.id }}">
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
            </div>
        {% endif %}
    </div>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
    (function () {
        var BASE = 'display:inline-block; padding:.5rem 1.25rem; border-radius:.4rem .4rem 0 0; font-weight:600; font-size:.9rem; border:none; cursor:pointer; ';
        var ACTIVE   = BASE + 'background:#FFD600; color:#00263A;';
        var INACTIVE = BASE + 'background:#023D5C; color:#ffffff;';

        function switchTab(tabName) {
            document.querySelectorAll('.admin-billing-panel').forEach(function (p) {
                p.style.display = p.id === 'tab-' + tabName ? '' : 'none';
            });
            document.querySelectorAll('.admin-billing-tab-btn').forEach(function (b) {
                b.style.cssText = b.dataset.tab === tabName ? ACTIVE : INACTIVE;
            });
            var url = new URL(window.location);
            url.searchParams.set('tab', tabName);
            history.replaceState(null, '', url);
        }

        document.addEventListener('DOMContentLoaded', function () {
            var initial = new URLSearchParams(window.location.search).get('tab') || 'website';
            switchTab(initial);

            document.querySelectorAll('.admin-billing-tab-btn').forEach(function (btn) {
                btn.addEventListener('click', function () { switchTab(btn.dataset.tab); });
            });

            document.querySelectorAll('.admin-toggle').forEach(function (cb) {
                cb.addEventListener('change', function () {
                    var url = cb.dataset.url;
                    if (!url) return;
                    fetch(url, { method: 'GET' })
                        .then(function () {
                            // Si on décoche "Facturé", désactive "Payé"
                            var sel = cb.dataset.nextCbSelector;
                            if (sel) {
                                var nextCb = document.querySelector(sel);
                                if (nextCb) {
                                    nextCb.disabled = !cb.checked;
                                    if (!cb.checked) { nextCb.checked = false; }
                                }
                            }
                        })
                        .catch(function () { cb.checked = !cb.checked; });
                });
            });
        });
    })();
    </script>
{% endblock %}

